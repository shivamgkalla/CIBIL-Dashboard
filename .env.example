# ── Required ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cibil_dashboard
SECRET_KEY=change-me-to-a-long-random-string

# ── Application ─────────────────────────────────────────────
DEBUG=False
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment mode: "dev" or "prod"
#   dev  → forgot-password returns reset link in API response (demo mode, no email needed)
#   prod → reset link sent via SMTP only, never exposed in API response
ENV=dev

# ── CORS (JSON array of allowed origins) ────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Password Reset ──────────────────────────────────────────
# Frontend URL where the reset-password page lives (token appended as ?token=...)
RESET_LINK_BASE_URL=http://localhost:3000/reset-password

# ── SMTP (required in prod mode for password reset emails) ──
# Not needed when ENV=dev (demo mode returns reset link directly)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=True

# ── Admin Seed (used by seed_admin.py on first deploy) ────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
