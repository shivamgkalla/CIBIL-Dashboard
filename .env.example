# ── Required ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cibil_dashboard
SECRET_KEY=change-me-to-a-long-random-string

# ── Application ─────────────────────────────────────────────
DEBUG=False
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS (JSON array of allowed origins) ────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Password Reset ──────────────────────────────────────────
RESET_LINK_BASE_URL=http://localhost:3000/reset-password

# ── SMTP (required for password reset emails in production) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=True
